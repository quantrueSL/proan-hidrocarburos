# Copia este fichero a `.env` (git-ignored) y rellena los valores.
# docker compose lo lee automáticamente para sustituir las variables.

# --- LLM (Gemini) para redactar las historias de alertas ---
# Endpoint OpenAI-compatible de Gemini + modelo. La API key es un secreto.
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL_ID=gemini-3.1-flash-lite
LLM_API_KEY=
