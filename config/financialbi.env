# =============================================================================
# FinancialBI — conexión a datos (DESARROLLO LOCAL)
# Se inyecta como env_file en docker-compose.yml. Cambios aquí solo requieren
# reiniciar carb-financialbi (no rebuild).
# =============================================================================

# Backend de datos: siempre BigQuery en Hidrocarburos.
FINANCIALBI_DB_BACKEND=bigquery

# --- BigQuery ---
# De momento apuntamos a los datos de Maka (proyecto proan-quantrue) para poder
# ver report + alertas. Cuando existan las tablas de hidrocarburos se cambiará
# el proyecto/dataset aquí y en report_engine.py / alertas_engine.py /
# materialize_alerts.py (nombres de tabla aún hardcodeados).
BQ_PROJECT_ID=proan-quantrue
BQ_LOCATION=us-west4
BQ_CREDENTIALS_PATH=/app/config/bq_credentials.json

# --- Presentación (se devuelven en /catalog y los usa el frontend) ---
FINANCIALBI_CURRENCY=MXN
FINANCIALBI_QTY_UNIT=Kg
